{
  "$schema": "https://opencode.ai/config.json",
  "version": "1.1.0",
  "level": "L3",
  "role": "application-project",
  "name": "knowledge-assistant-dev",
  "description": "应用项目层 - 知识助手开发项目",
  
  "hierarchy": {
    "level": "L3",
    "position": "应用项目层",
    "relationship": {
      "depends_on": ["L0", "L1", "L2"],
      "type": "具体业务实现"
    }
  },
  
  "dependencies": {
    "L0": {
      "name": "SEARCH-R",
      "path": "../SEARCH-R",
      "type": "methodology",
      "description": "研究方法论支撑"
    },
    "L1": {
      "name": "agent-team-research",
      "path": "../agent-team-research",
      "type": "research-support",
      "description": "研究能力支撑",
      "submodule": {
        "enabled": true,
        "path": ".agent-team/research"
      }
    },
    "L2": {
      "name": "AgentTeam-Template",
      "path": "../AgentTeam-Template",
      "type": "project-template",
      "description": "项目管理框架",
      "submodule": {
        "enabled": true,
        "path": ".agent-team/template"
      }
    }
  },
  
  "collaboration": {
    "feedback_path": "collaboration/feedback/",
    "dependency_docs": "collaboration/dependencies/"
  },
  
  "migration": {
    "status": "in_progress",
    "started": "2026-03-08",
    "notes": "正在进行多仓库架构调整，研究内容将迁移到L1"
  },
  
  "agent": {
    "pm": {
      "description": "PM - 项目管理和协调",
      "mode": "primary",
      "prompt": "{file:./practice/agents/pm/CATCH_UP.md}",
      "skills": [
        "git-workflow",
        "review-process",
        "quality-gate"
      ],
      "memory_index": "framework/memory-index.yaml",
      "permission": {
        "edit": "ask",
        "bash": {
          "git push": "ask",
          "git *": "allow"
        }
      }
    },
    "core": {
      "description": "Core - 核心数据处理和工具开发",
      "mode": "primary",
      "prompt": "{file:./practice/agents/core/CATCH_UP.md}",
      "skills": [
        "git-workflow",
        "quality-gate"
      ],
      "memory_index": "framework/memory-index.yaml",
      "permission": {
        "edit": "ask",
        "bash": {
          "git push": "ask",
          "pytest *": "allow",
          "black *": "allow",
          "flake8 *": "allow",
          "mypy *": "allow"
        }
      }
    },
    "ai": {
      "description": "AI - 向量嵌入和语义搜索",
      "mode": "primary",
      "prompt": "{file:./practice/agents/ai/CATCH_UP.md}",
      "skills": [
        "git-workflow",
        "quality-gate"
      ],
      "memory_index": "framework/memory-index.yaml",
      "permission": {
        "edit": "ask",
        "bash": {
          "git push": "ask",
          "pytest *": "allow",
          "black *": "allow",
          "flake8 *": "allow",
          "mypy *": "allow"
        }
      }
    },
    "integration": {
      "description": "Integration - opencode集成和连接器开发",
      "mode": "primary",
      "prompt": "{file:./practice/agents/integration/CATCH_UP.md}",
      "skills": [
        "git-workflow",
        "quality-gate"
      ],
      "memory_index": "framework/memory-index.yaml",
      "permission": {
        "edit": "ask",
        "bash": {
          "git push": "ask",
          "pytest *": "allow",
          "black *": "allow",
          "flake8 *": "allow",
          "mypy *": "allow"
        }
      }
    },
    "test": {
      "description": "Test - 测试框架和质量保证",
      "mode": "primary",
      "prompt": "{file:./practice/agents/test/CATCH_UP.md}",
      "skills": [
        "git-workflow",
        "quality-gate"
      ],
      "memory_index": "framework/memory-index.yaml",
      "permission": {
        "edit": "deny",
        "bash": {
          "pytest *": "allow",
          "git diff": "allow",
          "git log*": "allow"
        }
      }
    },
    "research": {
      "description": "Research - 框架层面的研究专家，辅助用户形成Agent Team框架设计思路",
      "mode": "primary",
      "prompt": "{file:./agents/research/CATCH_UP.md}",
      "skills": [
        "git-workflow",
        "quality-gate"
      ],
      "memory_index": "framework/memory-index.yaml",
      "permission": {
        "edit": "ask",
        "bash": {
          "git push": "ask",
          "git add": "allow",
          "git commit": "allow"
        }
      }
    },
    "migration": {
      "description": "Migration - 专门负责仓库结构调整和内容迁移",
      "mode": "primary",
      "prompt": "{file:./agents/migration/CATCH_UP.md}",
      "permission": {
        "edit": "ask",
        "bash": {
          "git *": "ask",
          "mkdir *": "allow",
          "rm *": "ask",
          "cp *": "allow",
          "cat *": "allow"
        }
      }
    }
  }
}
